\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Control Plane Scalability Analysis.} On an A100 node with 32 concurrent mock workers, DIO maintains a per-request scheduling overhead of 14\,$\mu $s and zero failures across 1664 requests. The reported 1.9\,s p99 end-to-end TTFT is dominated by synthetic worker delay and reflects control-plane stability rather than model serving speed.}}{6}{figure.2}\protected@file@percent }
\newlabel{fig:scalability}{{2}{6}{\textbf {Control Plane Scalability Analysis.} On an A100 node with 32 concurrent mock workers, DIO maintains a per-request scheduling overhead of 14\,$\mu $s and zero failures across 1664 requests. The reported 1.9\,s p99 end-to-end TTFT is dominated by synthetic worker delay and reflects control-plane stability rather than model serving speed}{figure.2}{}}
