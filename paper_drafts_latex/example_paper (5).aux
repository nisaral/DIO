\@writefile{toc}{\contentsline {subsection}{\numberline {4.5}Ablation Study: Component Contribution}{7}{subsection.4.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {End-to-End Performance \& Reliability Comparison on A100 Hardware.} The top row displays p99 TTFT (lower is better), while the bottom row displays SLO Attainment (higher is better). \textbf  {(Left) ShareGPT:} DIO reduces p99 TTFT by avoiding head-of-line blocking. \textbf  {(Center) arXiv:} The baseline (RR) suffers severe VRAM thrashing, driving p99 TTFT to ${>}80$\,s, while DIO maintains stable performance via admission control. \textbf  {(Right) Azure Code:} DIO handles bursty decoding times effectively, maintaining 88\% SLO attainment versus 12\% for the baseline.}}{8}{figure.3}\protected@file@percent }
\newlabel{fig:line_comparison}{{3}{8}{\textbf {End-to-End Performance \& Reliability Comparison on A100 Hardware.} The top row displays p99 TTFT (lower is better), while the bottom row displays SLO Attainment (higher is better). \textbf {(Left) ShareGPT:} DIO reduces p99 TTFT by avoiding head-of-line blocking. \textbf {(Center) arXiv:} The baseline (RR) suffers severe VRAM thrashing, driving p99 TTFT to ${>}80$\,s, while DIO maintains stable performance via admission control. \textbf {(Right) Azure Code:} DIO handles bursty decoding times effectively, maintaining 88\% SLO attainment versus 12\% for the baseline}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Adaptive Routing in Heterogeneous Environments.} Standard Round Robin (RR) assigns 50\% of traffic to the slow worker, causing immediate bottlenecks. DIO's NLMS scheduler identifies the throughput discrepancy within seconds and routes $\approx $75\% of requests to the fast worker, optimizing aggregate cluster utilization.}}{8}{figure.4}\protected@file@percent }
\newlabel{fig:req_dist}{{4}{8}{\textbf {Adaptive Routing in Heterogeneous Environments.} Standard Round Robin (RR) assigns 50\% of traffic to the slow worker, causing immediate bottlenecks. DIO's NLMS scheduler identifies the throughput discrepancy within seconds and routes $\approx $75\% of requests to the fast worker, optimizing aggregate cluster utilization}{figure.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces \textbf  {Ablation Study (L4 T2).} The Full DIO configuration delivers the lowest p99 TTFT with zero failures. Removing the Roofline admission control ($-$VRAM) results in a 23\% failure rate due to OOM errors. Removing Queue awareness ($-$Queue) causes p99 TTFT to spike to near-baseline levels.}}{8}{figure.5}\protected@file@percent }
\newlabel{fig:ablation}{{5}{8}{\textbf {Ablation Study (L4 T2).} The Full DIO configuration delivers the lowest p99 TTFT with zero failures. Removing the Roofline admission control ($-$VRAM) results in a 23\% failure rate due to OOM errors. Removing Queue awareness ($-$Queue) causes p99 TTFT to spike to near-baseline levels}{figure.5}{}}
