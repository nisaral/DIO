\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Comparison of LLM serving systems. DIO is the first control-plane orchestrator to combine zero-config dual-timescale NLMS prediction, Roofline-inspired per-request VRAM admission, and $O(1)$ scheduling while remaining completely non-invasive to production engines such as vLLM or SGLang.}}{2}{table.1}\protected@file@percent }
\newlabel{tab:systems_comparison}{{1}{2}{Comparison of LLM serving systems. DIO is the first control-plane orchestrator to combine zero-config dual-timescale NLMS prediction, Roofline-inspired per-request VRAM admission, and $O(1)$ scheduling while remaining completely non-invasive to production engines such as vLLM or SGLang}{table.1}{}}
