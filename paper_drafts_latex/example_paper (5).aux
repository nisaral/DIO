\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {DIO System Architecture.} The centralized Control Plane (Go) decouples scheduling logic from execution. The \textit  {NLMS Predictor} and \textit  {Cost-Based Scheduler} operate on the hot path, routing requests via gRPC to heterogeneous Python workers. Workers piggyback real-time latency and VRAM telemetry onto inference responses, closing the feedback loop.}}{3}{figure.1}\protected@file@percent }
\newlabel{fig:architecture}{{1}{3}{\textbf {DIO System Architecture.} The centralized Control Plane (Go) decouples scheduling logic from execution. The \textit {NLMS Predictor} and \textit {Cost-Based Scheduler} operate on the hot path, routing requests via gRPC to heterogeneous Python workers. Workers piggyback real-time latency and VRAM telemetry onto inference responses, closing the feedback loop}{figure.1}{}}
